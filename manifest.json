{
  "UUID": "com.ulanzi.devcontrol",
  "Name": "Device Pilot",
  "Description": "System-wide control of camera, microphone, and audio output on Windows.",
  "Author": "Walfrosch92",
  "Version": "1.0.0",
  "Icon": "assets/icons/icon_plugin.svg",
  "CategoryIcon": "assets/icons/icon_plugin.svg",
  "Category": "System Control",
  "CodePath": "plugin.js",
  "Type": "JavaScript",
  "PrivateAPI": true,
  "OS": [
    {
      "Platform": "windows",
      "MinimumVersion": "10"
    }
  ],
  "Software": {
    "MinimumVersion": "6.1"
  },
  "Actions": [
    {
      "UUID": "com.ulanzi.devcontrol.audiooutput",
      "Name": "Audio Output",
      "Icon": "assets/icons/speaker_on.png",
      "Tooltip": "Switch the default audio output device or toggle mute system-wide.",
      "PropertyInspectorPath": "property-inspector/audio-output.html",
      "SupportedInMultiActions": true,
      "States": [
        {
          "Name": "Active",
          "Image": "assets/icons/speaker_on.png"
        }
      ]
    },
    {
      "UUID": "com.ulanzi.devcontrol.microphone",
      "Name": "Microphone",
      "Icon": "assets/icons/mic_on.png",
      "Tooltip": "Switch or mute the default microphone system-wide.",
      "PropertyInspectorPath": "property-inspector/microphone.html",
      "SupportedInMultiActions": true,
      "States": [
        {
          "Name": "Active",
          "Image": "assets/icons/mic_on.png"
        },
        {
          "Name": "Muted",
          "Image": "assets/icons/mic_off.png"
        }
      ]
    },
    {
      "UUID": "com.ulanzi.devcontrol.camera",
      "Name": "Camera",
      "Icon": "assets/icons/cam_on.png",
      "Tooltip": "Mute/unmute the virtual camera or switch between physical cameras.",
      "PropertyInspectorPath": "property-inspector/camera.html",
      "SupportedInMultiActions": true,
      "States": [
        {
          "Name": "Live",
          "Image": "assets/icons/cam_on.png"
        },
        {
          "Name": "Muted",
          "Image": "assets/icons/cam_off.png"
        }
      ]
    }
  ]
}
